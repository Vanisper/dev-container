# 注意：推荐执行 scripts/ensure-env.sh 自动生成 .env，生成值会使用绝对路径。
# 代码工作区（按项目分，所有容器共享）
WORKSPACE_HOST=/absolute/path/to/dev-container/workspace

# 共享配置路径（git、ssh、bash、vim、tmux 等，所有容器共用）
SHARED_HOST=/absolute/path/to/dev-container/shared

# 容器内 dev 用户 ID（Mac 通常是 501，Linux 普通用户通常是 1000；root 宿主机也使用 1000）
DEV_UID=1000
DEV_GID=1000

# 容器名前缀（避免多人共用服务器冲突）
COMPOSE_PROJECT_NAME=dev

# 可选：Debian apt 镜像源。服务器访问 deb.debian.org 很慢时可启用。
# 示例：APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
APT_MIRROR=

# 可选：工具链自定义镜像源。仅在 ENV 使用 <tool>@custom 时生效。
# Go 示例：make up ENV=go@custom
GO_DOWNLOAD_MIRROR=

# Node 示例：make up ENV=node@custom
NODE_DOWNLOAD_MIRROR=

# Python 示例：make up ENV=python@custom
PYTHON_DOWNLOAD_MIRROR=
PYTHON_PIP_INDEX_URL=

# Rust 示例：make up ENV=rust@custom
RUSTUP_DIST_SERVER=
RUSTUP_UPDATE_ROOT=

# 示例：CARGO_REGISTRY_MIRROR=sparse+https://mirrors.ustc.edu.cn/crates.io-index/
CARGO_REGISTRY_MIRROR=
