TOOLCHAIN_NAME=python
TOOLCHAIN_VERSION=3.12.13
TOOLCHAIN_DESCRIPTION="Python toolchain"
TOOLCHAIN_ROOT="${DEV_ENV_HOME:-/opt/dev-env}/python"
TOOLCHAIN_HOME="$TOOLCHAIN_ROOT/home"
TOOLCHAIN_CACHE="$TOOLCHAIN_ROOT/cache"
TOOLCHAIN_CONFIG="$TOOLCHAIN_ROOT/config"
TOOLCHAIN_PREFIX="$TOOLCHAIN_ROOT/toolchain"
PYTHON_DEFAULT_PACKAGES="black flake8 pytest ipython"
